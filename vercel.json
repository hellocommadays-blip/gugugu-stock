{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    { "path": "/api/notify",       "schedule": "30 6 * * 1-5" },
    { "path": "/api/notify",       "schedule": "0 22 * * 1-5" },
    { "path": "/api/sync-stocks?offset=0&limit=40",  "schedule": "0 23 * * 1-5" },
    { "path": "/api/sync-stocks?offset=40&limit=40", "schedule": "5 23 * * 1-5" },
    { "path": "/api/sync-stocks?offset=80&limit=40", "schedule": "10 23 * * 1-5" }
  ]
}
