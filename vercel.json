{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "crons": [
    {
      "path": "/api/notify",
      "schedule": "30 6 * * 1-5"
    },
    {
      "path": "/api/notify",
      "schedule": "0 22 * * 1-5"
    }
  ]
}
